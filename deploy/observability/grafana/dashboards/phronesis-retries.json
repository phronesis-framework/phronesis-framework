{
  "uid": "phronesis-retries",
  "title": "Phronesis — Retries / Resilience",
  "tags": ["phronesis", "retries", "resilience"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {"name": "provider", "type": "query", "datasource": {"type": "prometheus", "uid": "phronesis-prom"}, "query": "label_values(phronesis_retry_attempts_total, provider_name)", "refresh": 2, "includeAll": true, "multi": true}
    ]
  },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Retry attempts / min by provider",
      "datasource": {"type": "prometheus", "uid": "phronesis-prom"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum by (provider_name) (rate(phronesis_retry_attempts_total{provider_name=~\"$provider\"}[1m])) * 60", "refId": "A", "legendFormat": "{{provider_name}}"}]
    },
    {
      "id": 2, "type": "timeseries", "title": "Retries by error type",
      "datasource": {"type": "prometheus", "uid": "phronesis-prom"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "sum by (error_type) (rate(phronesis_retry_attempts_total{provider_name=~\"$provider\"}[1m])) * 60", "refId": "A", "legendFormat": "{{error_type}}"}]
    },
    {
      "id": 3, "type": "table", "title": "Top error types (1h)",
      "datasource": {"type": "prometheus", "uid": "phronesis-prom"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [{"expr": "topk(10, sum by (error_type, provider_name) (increase(phronesis_retry_attempts_total{provider_name=~\"$provider\"}[1h])))", "refId": "A", "format": "table", "instant": true}]
    }
  ]
}
