{
  "uid": "phronesis-pipelines",
  "title": "Phronesis — Pipelines",
  "tags": ["phronesis", "pipelines"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {"name": "pipeline", "type": "query", "datasource": {"type": "prometheus", "uid": "phronesis-prom"}, "query": "label_values(phronesis_pipeline_runs_total, pipeline_name)", "refresh": 2, "includeAll": true, "multi": true}
    ]
  },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Pipeline runs / min by name",
      "datasource": {"type": "prometheus", "uid": "phronesis-prom"},
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 0},
      "targets": [{"expr": "sum by (pipeline_name) (rate(phronesis_pipeline_runs_total{pipeline_name=~\"$pipeline\"}[1m])) * 60", "refId": "A", "legendFormat": "{{pipeline_name}}"}]
    },
    {
      "id": 2, "type": "piechart", "title": "Success vs error",
      "datasource": {"type": "prometheus", "uid": "phronesis-prom"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [
        {"expr": "sum(increase(phronesis_pipeline_runs_total{operation_success=\"true\", pipeline_name=~\"$pipeline\"}[1h]))", "refId": "OK", "legendFormat": "success"},
        {"expr": "sum(increase(phronesis_pipeline_runs_total{operation_success=\"false\", pipeline_name=~\"$pipeline\"}[1h]))", "refId": "ERR", "legendFormat": "error"}
      ]
    },
    {
      "id": 3, "type": "heatmap", "title": "Pipeline run duration heatmap",
      "datasource": {"type": "prometheus", "uid": "phronesis-prom"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 8},
      "targets": [{"expr": "sum by (le) (rate(phronesis_pipeline_run_duration_seconds_bucket{pipeline_name=~\"$pipeline\"}[5m]))", "refId": "A", "format": "heatmap"}]
    }
  ]
}
